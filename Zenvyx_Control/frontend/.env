const ORG_ID = "919155911"; // Colocamos direto aqui também!
// const TOKEN = import.meta.env.VITE_ZOHO_TOKEN; <-- Deixamos o Vite fora dessa por enquanto
const TOKEN = "1000.bd2d394f2f0f4eca49563f8fef55f292.1b2877a23810955cf22ce5d123a722bc"; // <-- COLE AQUI DENTRO DAS ASPAS!

export const fetchZoho = async (endpoint, options = {}) => {
  const url = `/api/zoho/inventory/v1${endpoint}?organization_id=${ORG_ID}`;
  
  const headers = {
    'Authorization': `Zoho-oauthtoken ${TOKEN}`, 
    'Content-Type': 'application/json', 
    ...options.headers,
  };

  const response = await fetch(url, { ...options, headers });
  const data = await response.json();

  if (!response.ok || data.code !== 0) {
    console.error("Erro detalhado do Zoho:", data);
    throw new Error(data.message || 'Erro na comunicação com a API');
  }

  return data;
};